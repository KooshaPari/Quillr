# Quillr - TypeScript CLI tool
# Required environment variables

# Quillr Configuration
QUILLR_CONFIG_DIR=~/.config/quillr
QUILLR_DATA_DIR=~/.local/share/quillr

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# API (optional)
QUILLR_API_URL=https://api.phenotype.dev
QUILLR_API_TOKEN=your-token-here

# Editor
QUILLR_EDITOR=vim
QUILLR_PAGER=less
